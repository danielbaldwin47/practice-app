# Spike credentials. Throwaway, LAN-unreachable (all ports bound to 127.0.0.1).
# The real deployment must source these from TrueNAS app config, not a repo file.
PG_SUPERUSER_PASSWORD=spike_superuser_pw
PG_API_PASSWORD=spike_api_pw
PG_REPL_PASSWORD=spike_repl_pw
PG_STORAGE_PASSWORD=spike_storage_pw

MINIO_ROOT_USER=spikeadmin
MINIO_ROOT_PASSWORD=spike_minio_pw

# High, localhost-only host ports: 5432 is already taken by a production Postgres
# on this NAS, and 8080/9000 are crowded too.
HOST_PG_PORT=15432
HOST_POWERSYNC_PORT=15080
HOST_API_PORT=15060
HOST_MINIO_PORT=15900
HOST_MINIO_CONSOLE_PORT=15901

# Only used with `--profile tunnel`.
TUNNEL_TOKEN=
